---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You">
  <section style="padding: 4rem 1rem; max-width: 700px; margin: 0 auto; min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
    <h1 style="font-family: 'Playfair Display', serif; font-size: 2.5rem; margin-bottom: 1rem;">Thank You for Booking!</h1>
    <p style="font-size: 1.2rem; color: var(--muted); line-height: 1.7; max-width: 520px;">
      I'm looking forward to meeting with you. Keep an eye on your inbox for a calendar confirmation.
    </p>
    <p style="font-size: 1rem; color: var(--muted); margin-top: 2rem;">
      In the meantime, feel free to check out <a href="/" style="color: var(--gold); text-decoration: underline;">what VoiceCloser can do</a>.
    </p>
    <!-- Video will go here -->
  </section>
</Layout>

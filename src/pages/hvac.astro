---
import LandingLayout from '../layouts/LandingLayout.astro';
---
<LandingLayout title="HVAC">

  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <h1>Stop Losing HVAC Jobs To Missed Calls.</h1>
        <p class="hero-sub">
          Your own AI phone agent that answers every call, follows up on old service quotes,
          and books appointments - professionally, consistently, 24/7. Less drama, more jobs on the books.
        </p>

        <div class="demo-cta">
          <div class="demo-cta-eyecatch">
            <div class="phone-pulse">
              <div class="phone-pulse-icon">&#128222;</div>
            </div>
            <div class="demo-cta-eyecatch-text">
              Test it yourself
              <span>Don't take our word for it - hear it live</span>
            </div>
          </div>
          <form action="#" method="POST" id="heroHvacForm" class="demo-form">
            <div class="demo-cta-row">
              <input type="tel" name="phone" placeholder="Enter your mobile number" required />
              <button type="submit" class="btn btn-gold">Get A Free Test Call</button>
            </div>
            <input type="text" name="name" class="demo-name-field" placeholder="Your first name" autocomplete="given-name" />
          </form>
          <p class="demo-cta-helper">
            1 demo call. No spam. US &amp; Canada only. Works for inbound and outbound follow-up.
          </p>
        </div>
      </div>

      <div class="hero-visual">
        <div class="phone-mockup">
          <div class="phone-mockup-header">
            <div class="caller-name">Incoming Call</div>
            <div class="caller-status">VoiceCloser Answering...</div>
          </div>
          <div class="chat-bubble agent">
            Hi, thanks for calling! How can I help you?
          </div>
          <div class="chat-bubble caller">
            My AC stopped blowing cold air about an hour ago.
          </div>
          <div class="chat-bubble agent">
            That's no fun in this heat. Quick question - is the outdoor unit running, or is it completely silent outside?
          </div>
          <div class="chat-bubble caller">
            Actually I think it's running but the air inside is just warm.
          </div>
          <div class="chat-bubble agent">
            Okay, that's helpful. It could be a refrigerant issue or a compressor problem. I have an opening this afternoon at 2 PM. Want me to send a tech out?
          </div>
          <div class="chat-bubble caller">
            Yeah, please.
          </div>
          <div class="chat-bubble agent">
            Done. Tech will be there at 2. If you can, keep the thermostat set and don't keep turning it off and on before they arrive.
          </div>
        </div>

        <div class="hero-badge badge-top-right">
          <span class="badge-dot green"></span> 24/7 Coverage
        </div>
        <div class="hero-badge badge-mid-left">
          <span class="badge-dot gold"></span> Missed Calls: 0
        </div>
        <div class="hero-badge badge-bottom-right">
          <span class="badge-dot blue"></span> Service Calls Booked This Week: 18
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 2. PROBLEM SECTION ===== -->
  <section class="problem-section">
    <div class="problem-inner container">
      <div class="problem-text">
        <h2>When The AC Goes Out, They Call Everyone. Who Answers First Wins.</h2>
        <p>
          Summer heat doesn't wait. When a homeowner's AC dies, they're calling every
          HVAC company they can find. The one who picks up first gets the job. Everyone
          else gets forgotten.
        </p>
        <ul class="problem-list">
          <li>
            <span class="icon">&#10007;</span>
            <span>Peak season calls go to voicemail while your techs are in attics.</span>
          </li>
          <li>
            <span class="icon">&#10007;</span>
            <span>Maintenance agreement renewals expire with no follow-up.</span>
          </li>
          <li>
            <span class="icon">&#10007;</span>
            <span>Last year's estimate requests are collecting dust.</span>
          </li>
        </ul>
        <a href="#how-it-works" class="btn btn-outline btn-sm">See How VoiceCloser Fixes This</a>
      </div>

      <div class="comparison-card">
        <div class="comparison-side current">
          <div class="comparison-label">Current Reality</div>
          <div class="comparison-stat">
            <span class="stat-icon">&#128222;</span>
            <span class="stat-text">18 missed calls during a heat wave<br/>0 maintenance renewals followed up</span>
          </div>
        </div>
        <div class="comparison-side better">
          <div class="comparison-label">With VoiceCloser</div>
          <div class="comparison-stat">
            <span class="stat-icon">&#9989;</span>
            <span class="stat-text">18 answered, 11 service calls booked<br/>7 renewals re-engaged</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 3. THREE PILLARS ===== -->
  <section class="pillars-section">
    <div class="container text-center">
      <h2 class="section-title">One Voice Agent. Three Jobs You Hate Doing.</h2>
      <span class="gold-line"></span>
    </div>

    <div class="pillars-grid container">
      <div class="pillar-card">
        <div class="pillar-icon">&#128222;</div>
        <h3>Answer Every Call Live</h3>
        <p>
          Instantly answers every call with a professional, branded greeting so real
          people talk to a real-sounding agent instead of voicemail.
        </p>
      </div>
      <div class="pillar-card">
        <div class="pillar-icon">&#128269;</div>
        <h3>Qualify &amp; Route Serious Leads</h3>
        <p>
          Asks the right questions, filters tire-kickers, and emails you a summary
          of every serious lead or routes them to the right person.
        </p>
      </div>
      <div class="pillar-card">
        <div class="pillar-icon">&#128202;</div>
        <h3>Call Through Your Existing Database</h3>
        <p>
          Systematically calls your existing, opted-in leads to revive old conversations
          and turn past inquiries into fresh appointments.
        </p>
      </div>
    </div>

    <div class="container text-center mt-2">
      <a href="#" class="btn btn-outline">Watch A 60-Second Overview</a>
    </div>
  </section>

  <!-- ===== 4. HOW IT WORKS ===== -->
  <section class="steps-section" id="how-it-works">
    <div class="container text-center">
      <h2 class="section-title">Here's How VoiceCloser Goes Live In Days, Not Months.</h2>
      <span class="gold-line"></span>
    </div>

    <div class="steps-grid container">
      <div class="step-card">
        <div class="step-number">1</div>
        <h3>Quick Setup Call</h3>
        <p>
          We learn how your business works, what to say, and who counts as a qualified lead.
        </p>
      </div>
      <div class="step-card">
        <div class="step-number">2</div>
        <h3>We Train Your Voice Agent</h3>
        <p>
          We configure scripts, booking rules, and test calls until you're happy with every word.
        </p>
      </div>
      <div class="step-card">
        <div class="step-number">3</div>
        <h3>Forward Your Phones &amp; Plug In Your Leads</h3>
        <p>
          We start answering inbound calls and calling through your existing database. You focus on closing.
        </p>
      </div>
    </div>

    <div class="steps-flow container">
      <div class="flow-box">Caller / Lead List</div>
      <span class="flow-arrow">&#8594;</span>
      <div class="flow-box" style="border-color: var(--gold);">VoiceCloser</div>
      <span class="flow-arrow">&#8594;</span>
      <div class="flow-box">Calendar / Inbox / CRM</div>
    </div>

    <div class="container text-center mt-2">
      <button class="btn btn-gold btn-lg open-strategy-modal">Book A 15-Minute Strategy Call</button>
    </div>
  </section>

  <!-- ===== 5. DEMO BAND ===== -->
  <section class="demo-band" id="demo">
    <h2>Hear How VoiceCloser Handles An HVAC Service Call.</h2>
    <p class="demo-band-sub">
      Enter your number and VoiceCloser will call you in under a minute.
    </p>
    <div class="demo-cta">
      <div class="demo-cta-eyecatch" style="justify-content: center;">
        <div class="phone-pulse">
          <div class="phone-pulse-icon">&#128222;</div>
        </div>
        <div class="demo-cta-eyecatch-text">
          Try it live
          <span>Don't take our word for it - hear it live</span>
        </div>
      </div>
      <form action="#" method="POST" id="demoHvacForm" class="demo-form">
        <div class="demo-cta-row">
          <input type="tel" name="phone" placeholder="Enter your mobile number" required />
          <button type="submit" class="btn btn-gold">Get A Free Test Call</button>
        </div>
        <input type="text" name="name" class="demo-name-field" placeholder="Your first name" autocomplete="given-name" />
      </form>
      <p class="demo-cta-helper">
        1 demo call. No spam. US &amp; Canada only.
      </p>
    </div>
  </section>

  <!-- ===== 6. CALLS WE HANDLE ===== -->
  <section class="audience-section" id="who-its-for">
    <div class="audience-inner container">
      <div class="audience-text">
        <h2>Calls We Handle For HVAC Companies.</h2>
        <p>
          From emergency breakdowns to seasonal tune-ups, VoiceCloser handles the calls
          that keep your techs busy year-round.
        </p>
      </div>

      <ul class="audience-list">
        <li class="audience-pill">
          <span class="check">&#10003;</span>
          <span>Emergency AC and heating breakdown calls</span>
        </li>
        <li class="audience-pill">
          <span class="check">&#10003;</span>
          <span>Seasonal maintenance and tune-up scheduling</span>
        </li>
        <li class="audience-pill">
          <span class="check">&#10003;</span>
          <span>Estimate and quote follow-ups</span>
        </li>
        <li class="audience-pill">
          <span class="check">&#10003;</span>
          <span>Maintenance agreement renewals</span>
        </li>
        <li class="audience-pill">
          <span class="check">&#10003;</span>
          <span>After-hours emergency dispatch</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- ===== 7. SOCIAL PROOF ===== -->
  <section class="proof-section">
    <div class="proof-inner container">
      <div class="proof-card">
        <div class="quote-icon">&ldquo;</div>
        <p class="quote-text">
          As soon as we turned it on, we stopped missing calls and started seeing
          more booked jobs from leads we'd forgotten about. It paid for itself in
          the first week.
        </p>
        <p class="quote-author">
          <strong>- Client Name</strong>, Company (Placeholder)
        </p>
      </div>

      <div class="proof-card metrics-card">
        <h3>What clients see after turning on VoiceCloser</h3>
        <div class="metric-row">
          <span class="metric-number">0</span>
          <span class="metric-label">Missed calls during business hours</span>
        </div>
        <div class="metric-row">
          <span class="metric-number">2-5x</span>
          <span class="metric-label">More touchpoints on existing leads</span>
        </div>
        <div class="metric-row">
          <span class="metric-number">&lt;60s</span>
          <span class="metric-label">Typical response time</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 8. CTA BAND ===== -->
  <section class="cta-band" id="book">
    <h2>Want To See How Many HVAC Leads Slipped Through This Season?</h2>
    <p class="cta-band-sub">
      On a short call, we'll map your current missed calls and database, then show
      you how a voice agent could plug in.
    </p>
    <button class="btn btn-gold btn-lg open-strategy-modal">Book Your 15-Minute Strategy Call</button>
    <p class="cta-band-secondary">
      <a href="#demo">Not ready to talk? Get a free test call instead.</a>
    </p>
  </section>

  <!-- ===== 9. FAQ ===== -->
  <section class="faq-section" id="faq">
    <div class="container text-center">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <span class="gold-line"></span>
    </div>

    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <span>Can it handle seasonal call spikes?</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            Yes. VoiceCloser handles unlimited calls at the same time. During a heat
            wave or cold snap when your phone is ringing off the hook, every single
            call gets answered and scheduled. No overwhelmed front desk.
          </div>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <span>Do I have to switch phone numbers?</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            No. You keep your existing business number. We set up simple call forwarding
            so VoiceCloser answers when you can't. Your customers never notice a difference.
          </div>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <span>How long does setup take?</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            Most businesses are live within 3-5 business days. We handle the heavy
            lifting: scripting, testing, and configuration. All we need from you
            is one setup call and access to your lead list or CRM.
          </div>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <span>What CRMs and calendars can you work with?</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            VoiceCloser integrates with most major CRMs (GoHighLevel, Follow Up Boss,
            HubSpot, Salesforce, and more) and calendar tools (Google Calendar, Calendly,
            Cal.com). If you use it, we can probably connect to it.
          </div>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <span>What if the agent says something wrong?</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            Every agent is custom-trained on your business, services, and tone before
            going live. We test extensively and you approve the scripts. After launch,
            every call is logged and reviewed so we can continuously improve accuracy.
            You can update scripts or escalation rules at any time.
          </div>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <span>How much does it cost?</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            Pricing is customized based on your call volume, complexity, and whether
            you need inbound, outbound, or both. Book a strategy call and we'll give
            you a clear quote based on your specific situation. No surprises.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STRATEGY CALL MODAL ===== -->
  <div class="modal-backdrop" id="strategyModal">
    <div class="modal modal-tidycal">
      <button class="modal-close" id="modalClose" aria-label="Close">&times;</button>
      <div id="tidycalContainer"></div>
    </div>
  </div>

</LandingLayout>

<script is:inline>
  // FAQ accordion
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement;
      const answer = item.querySelector('.faq-answer');
      const isOpen = item.classList.contains('open');

      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-answer').style.maxHeight = null;
        i.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Strategy call modal with TidyCal
  (function() {
    const modal = document.getElementById('strategyModal');
    const closeBtn = document.getElementById('modalClose');
    const container = document.getElementById('tidycalContainer');
    let tidycalLoaded = false;

    function loadTidyCal() {
      if (tidycalLoaded) return;
      tidycalLoaded = true;

      // Insert the TidyCal embed div
      const embedDiv = document.createElement('div');
      embedDiv.className = 'tidycal-embed';
      embedDiv.setAttribute('data-path', 'rxross/voicecloser-strategy-call');
      container.appendChild(embedDiv);

      // Load the TidyCal script
      const script = document.createElement('script');
      script.src = 'https://asset-tidycal.b-cdn.net/js/embed.js';
      script.async = true;
      container.appendChild(script);
    }

    // Open modal
    document.querySelectorAll('.open-strategy-modal').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
        loadTidyCal();
      });
    });

    // Close modal
    function closeModal() {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }

    closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
  })();

  // Phone number auto-formatting: (267) 625-7559
  function formatPhone(value) {
    const digits = value.replace(/\D/g, '').slice(0, 10);
    if (digits.length === 0) return '';
    if (digits.length <= 3) return `(${digits}`;
    if (digits.length <= 6) return `(${digits.slice(0,3)}) ${digits.slice(3)}`;
    return `(${digits.slice(0,3)}) ${digits.slice(3,6)}-${digits.slice(6)}`;
  }

  // Strip formatting for API submission
  function stripPhone(value) {
    return value.replace(/\D/g, '');
  }

  // Demo call forms
  (function() {
    document.querySelectorAll('.demo-form').forEach(form => {
      const phoneInput = form.querySelector('input[name="phone"]');
      const nameField = form.querySelector('.demo-name-field');
      const btn = form.querySelector('button[type="submit"]');

      // Auto-format phone as user types
      phoneInput.addEventListener('input', () => {
        const cursor = phoneInput.selectionStart;
        const oldLen = phoneInput.value.length;
        phoneInput.value = formatPhone(phoneInput.value);
        const newLen = phoneInput.value.length;
        // Keep cursor in a reasonable spot
        phoneInput.setSelectionRange(cursor + (newLen - oldLen), cursor + (newLen - oldLen));

        // Reveal name field once they start typing
        if (stripPhone(phoneInput.value).length > 0) {
          nameField.classList.add('visible');
        } else {
          nameField.classList.remove('visible');
        }
      });

      // Reset form to initial state
      function resetForm(originalText) {
        btn.textContent = originalText;
        btn.style.background = '';
        btn.style.borderColor = '';
        btn.disabled = false;
        phoneInput.disabled = false;
        nameField.disabled = false;
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const phone = stripPhone(phoneInput.value);
        const name = (form.querySelector('input[name="name"]').value || '').trim();

        if (!phone || phone.length < 10) return;

        const originalText = btn.textContent;
        btn.textContent = 'Calling you now...';
        btn.disabled = true;
        phoneInput.disabled = true;
        nameField.disabled = true;

        try {
          const res = await fetch('/api/test-call-homepage', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone, name, agent: 'voicecloser_hvac' }),
          });

          const data = await res.json();

          if (data.success) {
            btn.textContent = 'Call incoming! Pick up your phone.';
            btn.style.background = '#34d399';
            btn.style.borderColor = '#34d399';
            // Reset after 15 seconds
            setTimeout(() => resetForm(originalText), 15000);
          } else {
            btn.textContent = data.error || 'Something went wrong. Try again.';
            btn.style.background = '#ef4444';
            btn.style.borderColor = '#ef4444';
            setTimeout(() => resetForm(originalText), 3000);
          }
        } catch (err) {
          btn.textContent = 'Connection error. Try again.';
          btn.style.background = '#ef4444';
          btn.style.borderColor = '#ef4444';
          setTimeout(() => resetForm(originalText), 3000);
        }
      });
    });
  })();
</script>

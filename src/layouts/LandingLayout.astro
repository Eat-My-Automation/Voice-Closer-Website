---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "VoiceCloser - 24/7 voice agent that answers your calls and revives old leads so more conversations turn into booked jobs."
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | VoiceCloser</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,700;0,800;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- MINIMAL TOP BAR -->
    <nav class="navbar" aria-label="Main navigation">
      <div class="navbar-inner">
        <a href="/" class="navbar-logo">
          <img src="/logo.jpg" alt="VoiceCloser" class="logo-img" />
          Voice<span>Closer</span>
        </a>

        <div class="navbar-right">
          <button class="btn btn-gold btn-sm open-strategy-modal">Book A Strategy Call</button>
          <button class="theme-toggle" id="themeToggle" aria-label="Toggle light/dark mode">
            <span class="icon-sun">&#9728;</span>
            <span class="icon-moon">&#9790;</span>
          </button>
        </div>
      </div>
    </nav>

    <!-- PAGE CONTENT -->
    <main>
      <slot />
    </main>

    <!-- MINIMAL FOOTER -->
    <footer class="footer" aria-label="Site footer">
      <div class="footer-inner" style="grid-template-columns: 2fr 1fr;">
        <div class="footer-brand">
          <a href="/" class="navbar-logo">
            <img src="/logo.jpg" alt="VoiceCloser" class="logo-img" />
            Voice<span>Closer</span>
          </a>
          <p>VoiceCloser helps call-heavy businesses answer every call and revive old leads with a 24/7 voice agent.</p>
        </div>

        <div class="footer-cta">
          <h4>Get Started</h4>
          <button class="btn btn-gold btn-sm open-strategy-modal">Book A Strategy Call</button>
        </div>
      </div>

      <div class="footer-bottom">
        <span>&copy; {new Date().getFullYear()} VoiceCloser. All rights reserved.</span>
      </div>
    </footer>

    <script is:inline>
      // Theme toggle
      (function() {
        const toggle = document.getElementById('themeToggle');
        const stored = localStorage.getItem('vc-theme');
        if (stored === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }

        toggle.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme');
          if (current === 'light') {
            document.documentElement.removeAttribute('data-theme');
            localStorage.setItem('vc-theme', 'dark');
          } else {
            document.documentElement.setAttribute('data-theme', 'light');
            localStorage.setItem('vc-theme', 'light');
          }
        });
      })();
    </script>
  </body>
</html>
